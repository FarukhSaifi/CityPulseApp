{
  "name": "citypulseapp",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --dev-client --android",
    "ios": "expo start --dev-client --ios",
    "start:go": "expo start --go",
    "build:ios:simulator": "eas build --platform ios --profile development-simulator",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile development",
    "build:ios": "eas build --platform ios --profile development",
    "build:all": "eas build --platform all --profile development"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/stack": "^7.10.5",
    "babel-preset-expo": "~56.0.0",
    "expo": "~56.0.0",
    "expo-asset": "~56.0.17",
    "expo-dev-client": "~56.0.20",
    "expo-font": "~56.0.7",
    "expo-linear-gradient": "~56.0.4",
    "expo-local-authentication": "~56.0.4",
    "expo-localization": "~56.0.6",
    "expo-splash-screen": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.15.0",
    "i18n-js": "^4.5.3",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
